+++ b/pkg/passwordreset/hkbp_setup_link_spike_test.go
@@ -0,0 +1,44 @@
+package passwordreset
+
+import (
+	"net/url"
+	"strings"
+	"testing"
+	"time"
+
+	"github.com/eugenioenko/autentico/pkg/config"
+	"github.com/eugenioenko/autentico/pkg/user"
+	"github.com/eugenioenko/autentico/pkg/utils"
+	testutils "github.com/eugenioenko/autentico/tests/utils"
+	"github.com/stretchr/testify/require"
+)
+
+func TestHKBPSpike_CreateSetupPasswordLinkForNoEmailUser(t *testing.T) {
+	testutils.WithTestDB(t)
+	testutils.WithConfigOverride(t, func() {
+		config.Bootstrap.AppURL = "https://auth.hkbp.zahranm.cloud"
+		config.Bootstrap.AppOAuthPath = "/oauth2"
+		config.Values.ProfileFieldEmail = "hidden"
+		config.Values.PasswordResetExpiration = 24 * time.Hour
+	})
+
+	created, err := user.CreateUser("amang-budi", "random-unusable-bootstrap-secret", "")
+	require.NoError(t, err)
+
+	link, err := CreateSetupPasswordLink(created.ID)
+	require.NoError(t, err)
+	require.NotEmpty(t, link.SetupURL)
+	require.True(t, link.ExpiresAt.After(time.Now()))
+	require.True(t, strings.HasPrefix(link.SetupURL, "https://auth.hkbp.zahranm.cloud/oauth2/reset-password?"))
+
+	parsed, err := url.Parse(link.SetupURL)
+	require.NoError(t, err)
+	require.NotEmpty(t, parsed.Query().Get("token"))
+
+	tokenHash := utils.HashSHA256(parsed.Query().Get("token"))
+	userID, expiresAt, usedAt, err := getResetTokenInfo(tokenHash)
+	require.NoError(t, err)
+	require.Equal(t, created.ID, userID)
+	require.Nil(t, usedAt)
+	require.True(t, expiresAt.After(time.Now()))
+}
