@@ -0,0 +1,43 @@
+package user
+
+import (
+	"testing"
+
+	"github.com/eugenioenko/autentico/pkg/config"
+	testutils "github.com/eugenioenko/autentico/tests/utils"
+	"github.com/stretchr/testify/require"
+)
+
+func TestHKBPSpike_CreatePasswordUserWithoutEmailWhenHidden(t *testing.T) {
+	testutils.WithTestDB(t)
+	testutils.WithConfigOverride(t, func() {
+		config.Values.ProfileFieldEmail = "hidden"
+	})
+
+	u, err := CreateUser("amang-budi", "password123", "")
+	require.NoError(t, err)
+	require.NotNil(t, u)
+	require.Equal(t, "amang-budi", u.Username)
+	require.Empty(t, u.Email)
+	require.NotEmpty(t, u.ID)
+
+	fetched, err := UserByID(u.ID)
+	require.NoError(t, err)
+	require.Equal(t, "amang-budi", fetched.Username)
+	require.Empty(t, fetched.Email)
+	require.NotEmpty(t, fetched.Password)
+	require.NotNil(t, fetched.RegisteredAt)
+}
+
+func TestHKBPSpike_CreateValidationAllowsNoEmailWhenHidden(t *testing.T) {
+	testutils.WithConfigOverride(t, func() {
+		config.Values.ProfileFieldEmail = "hidden"
+	})
+
+	err := ValidateUserCreateRequest(UserCreateRequest{
+		Username: "amang-budi",
+		Password: "password123",
+		Email:    "",
+	})
+	require.NoError(t, err)
+}
