+package passwordreset
+
+import (
+	"encoding/json"
+	"log/slog"
+	"net/http"
+	"time"
+
+	"github.com/eugenioenko/autentico/pkg/audit"
+	"github.com/eugenioenko/autentico/pkg/config"
+	"github.com/eugenioenko/autentico/pkg/reqid"
+	"github.com/eugenioenko/autentico/pkg/user"
+	"github.com/eugenioenko/autentico/pkg/utils"
+)
+
+type AdminSetupPasswordLinkResponse struct {
+	SetupURL  string    `json:"setup_url"`
+	ExpiresAt time.Time `json:"expires_at"`
+}
+
+// CreateSetupPasswordLink creates a one-time password setup/reset URL without sending email.
+// This is the minimal HKBP-needed primitive: admin-auth endpoint can return the URL/QR,
+// while the existing /oauth2/reset-password page handles password selection.
+func CreateSetupPasswordLink(userID string) (*AdminSetupPasswordLinkResponse, error) {
+	if _, err := user.UserByID(userID); err != nil {
+		return nil, err
+	}
+	invalidatePreviousTokens(userID)
+
+	rawToken, tokenHash, err := generateToken()
+	if err != nil {
+		return nil, err
+	}
+	expiresAt := time.Now().Add(config.Get().PasswordResetExpiration)
+	if err := createResetToken(userID, tokenHash, expiresAt); err != nil {
+		return nil, err
+	}
+
+	return &AdminSetupPasswordLinkResponse{
+		SetupURL:  buildResetURL(rawToken, oauthParams{}),
+		ExpiresAt: expiresAt,
+	}, nil
+}
+
+// HandleAdminCreateSetupPasswordLink godoc
+// @Summary Create one-time password setup link for a user
+// @Description Admin-only endpoint that returns a reset/setup URL instead of emailing it.
+// @Tags admin-users
+// @Produce json
+// @Param id path string true "User ID"
+// @Security AdminAuth
+// @Success 200 {object} AdminSetupPasswordLinkResponse
+// @Failure 400 {object} model.ApiError
+// @Failure 404 {object} model.ApiError
+// @Failure 500 {object} model.ApiError
+// @Router /admin/api/users/{id}/setup-password-link [post]
+func HandleAdminCreateSetupPasswordLink(w http.ResponseWriter, r *http.Request) {
+	userID := r.PathValue("id")
+	if userID == "" {
+		utils.WriteErrorResponse(w, http.StatusBadRequest, "invalid_request", "Missing user id")
+		return
+	}
+	response, err := CreateSetupPasswordLink(userID)
+	if err != nil {
+		slog.Error("passwordreset: failed to create setup link", "request_id", reqid.Get(r.Context()), "user_id", userID, "error", err)
+		utils.WriteErrorResponse(w, http.StatusInternalServerError, "server_error", "Failed to create setup link")
+		return
+	}
+	admin := audit.ActorFromRequest(r)
+	audit.Log(audit.EventPasswordResetRequested, admin, audit.TargetUser, userID, audit.Detail("source", "admin_setup_link"), utils.GetClientIP(r))
+
+	w.Header().Set("Content-Type", "application/json")
+	_ = json.NewEncoder(w).Encode(map[string]any{"data": response})
+}
diff --git a/pkg/passwordreset/hkbp_setup_link_spike_test.go b/pkg/passwordreset/hkbp_setup_link_spike_test.go
new file mode 100644
index 0000000..6a7aa07
