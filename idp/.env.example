# HKBP IdP (Auténtico) environment. Copy to .env on the IdP host. Keep secrets
# out of git. Variable names follow upstream Auténtico pkg/config (verified
# against the pinned AUTENTICO_REF; re-confirm on upgrades).

# Pin upstream to a reviewed commit before building the image.
AUTENTICO_REF=main

# Public base URL. Auténtico derives the issuer as <APP_URL>/oauth2, so the HKBP
# backend OIDC_ISSUER must be https://auth.hkbp.zahranm.cloud/oauth2.
AUTENTICO_APP_URL=https://auth.hkbp.zahranm.cloud
AUTENTICO_APP_OAUTH_PATH=/oauth2

# Listen port inside the container (Traefik routes to this).
AUTENTICO_LISTEN_PORT=9999

# SQLite state path on the persistent volume.
AUTENTICO_DB_FILE_PATH=/app/data/autentico.db

# Built-in admin account (seeds the autentico-admin client + admin user). The
# admin API the HKBP backend calls is protected by an admin OIDC token obtained
# via this account / the autentico-admin client.
AUTENTICO_ADMIN_USERNAME=hkbp-admin
AUTENTICO_ADMIN_PASSWORD=<generate-a-strong-password>
AUTENTICO_ADMIN_EMAIL=zsulthan9@gmail.com
# Allow the password grant so the HKBP backend (Stage B) can mint an admin token.
AUTENTICO_ENABLE_ADMIN_PASSWORD_GRANT=true

# Signing/secret material — generate strong random values.
AUTENTICO_ACCESS_TOKEN_SECRET=<random>
AUTENTICO_REFRESH_TOKEN_SECRET=<random>
AUTENTICO_CSRF_SECRET_KEY=<random>
# RSA private key (PEM) for OIDC ID-token signing; generate per upstream docs.
# AUTENTICO_RSA_PRIVATE_KEY=

# Cookies must be secure behind TLS.
AUTENTICO_CSRF_SECURE_COOKIE=true
AUTENTICO_IDP_SESSION_SECURE=true

# Backup retention in days (target 7-30).
IDP_BACKUP_RETENTION_DAYS=14

# ---------------------------------------------------------------------------
# Register the HKBP relying-party client AFTER first boot (it lives in the
# clients DB table, created via the admin API or the `autentico` CLI). The
# HKBP backend OIDC_CLIENT_ID/OIDC_CLIENT_SECRET/OIDC_REDIRECT_URL must match:
#   client_id:     hkbp-app
#   redirect_uri:  https://hkbp.zahranm.cloud/api/v1/auth/callback
#   post_logout:   https://hkbp.zahranm.cloud/login?logged_out=1
#   grant_types:   authorization_code, refresh_token
# See idp/README.md "Register the HKBP client".
# ---------------------------------------------------------------------------
