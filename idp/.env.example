# HKBP IdP (Auténtico) environment. Copy to .env on the IdP host. Keep secrets
# out of git. Exact variable names follow upstream Auténtico; confirm against the
# pinned AUTENTICO_REF.

# Pin upstream to a reviewed commit before building the image.
AUTENTICO_REF=main

# Public issuer URL (must match HKBP backend OIDC_ISSUER exactly).
AUTENTICO_APP_URL=https://auth.hkbp.zahranm.cloud

# SQLite state path on the persistent volume.
AUTENTICO_DB_FILE_PATH=/app/data/autentico.db

# Users without a personal email: hide/keep email optional.
AUTENTICO_PROFILE_FIELD_EMAIL=hidden

# OIDC client used by the HKBP app (RP). Must match the HKBP backend values:
#   OIDC_CLIENT_ID / OIDC_CLIENT_SECRET / OIDC_REDIRECT_URL
HKBP_OIDC_CLIENT_ID=hkbp-app
HKBP_OIDC_CLIENT_SECRET=<generate-a-strong-secret>
HKBP_OIDC_REDIRECT_URI=https://hkbp.zahranm.cloud/api/v1/auth/callback
HKBP_OIDC_POST_LOGOUT_REDIRECT_URI=https://hkbp.zahranm.cloud/login?logged_out=1

# Admin API token the HKBP backend uses for provisioning / setup-links / rename
# (IDP_ADMIN_TOKEN on the HKBP side). Generate a long random value.
AUTENTICO_ADMIN_API_TOKEN=<generate-a-strong-admin-token>

# Password reset/setup token lifetime (drives setup-link expiry).
AUTENTICO_PASSWORD_RESET_EXPIRATION=24h

# Backup retention in days (target 7-30).
IDP_BACKUP_RETENTION_DAYS=14
