# API base path. Same-origin in production (the Go server serves the SPA) and
# proxied to the backend in dev via vite.config.ts, so "/api/v1" works for both.
VITE_API_BASE_URL=/api/v1

# Override the dev proxy target if the backend runs elsewhere.
# VITE_DEV_API_TARGET=http://localhost:8080

# App
VITE_APP_NAME=HKBP Jatinegara
