# Server
PORT=8080

# Database (self-hosted Turso-compatible libSQL server)
TURSO_URL=http://127.0.0.1:8081
TURSO_AUTH_TOKEN=

# Single-container deployments can use embedded SQLite instead of libSQL HTTP.
# Set SQLITE_PATH=/app/data/hkbp-jatinegara.db in Dokploy and mount /app/data as a volume.
SQLITE_PATH=

# Managed Turso Cloud can use the same variables:
# TURSO_URL=libsql://hkbp-jatinegara-<your-org>.turso.io
# TURSO_AUTH_TOKEN=<your-turso-token>

# ---------------------------------------------------------------------------
# Authentication: backend-mediated OIDC + opaque hkbp_session cookie.
# The HKBP app holds NO passwords or JWTs; the IdP owns credentials. See
# docs/AUTH-DESIGN.md.
# ---------------------------------------------------------------------------

# OIDC relying-party config (HKBP is the RP; Auténtico is the IdP/OP).
OIDC_ISSUER=https://auth.hkbp.zahranm.cloud
OIDC_CLIENT_ID=hkbp-app
OIDC_CLIENT_SECRET=<oidc-client-secret-if-confidential>
# Defaults to APP_BASE_URL + /api/v1/auth/callback when unset.
OIDC_REDIRECT_URL=https://hkbp.zahranm.cloud/api/v1/auth/callback
OIDC_SCOPES=openid profile email

# HKBP app URLs used for post-auth redirects.
APP_BASE_URL=https://hkbp.zahranm.cloud
POST_LOGOUT_REDIRECT_URL=https://hkbp.zahranm.cloud/login?logged_out=1
ACCESS_PENDING_URL=https://hkbp.zahranm.cloud/access-pending

# Opaque cookie session.
SESSION_COOKIE_NAME=hkbp_session
# Leave blank unless the SPA and API are on different subdomains.
SESSION_COOKIE_DOMAIN=
# Defaults to true when APP_BASE_URL is https. Set false only for local http dev.
SESSION_COOKIE_SECURE=true
# Session lifetime in seconds (default 43200 = 12h).
SESSION_TTL=43200

# IdP management API for provisioning, one-time setup links, and username rename.
# Defaults to OIDC_ISSUER when unset.
IDP_ADMIN_BASE_URL=https://auth.hkbp.zahranm.cloud
IDP_ADMIN_TOKEN=<idp-admin-api-token>
# Only enable after confirming the IdP exposes a username rename endpoint;
# otherwise rename is reported as blocked to avoid HKBP/IdP drift.
IDP_SUPPORTS_USERNAME_RENAME=false

# Bootstrap: while no active admin exists, the verified OIDC email matching this
# value is promoted to the first active admin on login. Inert afterwards.
BOOTSTRAP_ADMIN_EMAIL=

# Rejected/disabled re-request cooldown in seconds (default 7200 = 2h).
ACCESS_REQUEST_COOLDOWN=7200

# CORS. With same-origin deployment this is unused; set it only if the SPA is
# served from a different origin (must be an exact origin, not *, with cookies).
CORS_ORIGIN=http://localhost:5173

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880

# Optional: serve the built Vue SPA from the Go backend in production.
# The Dockerfile sets this to /app/frontend/dist.
STATIC_DIR=

# Optional: override the migrations directory (defaults to ./migrations).
MIGRATIONS_DIR=
