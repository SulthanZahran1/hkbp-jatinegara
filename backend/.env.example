# Server
PORT=8080

# Database (Turso)
TURSO_URL=libsql://hkbp-jatinegara-<your-org>.turso.io
TURSO_AUTH_TOKEN=<your-turso-token>

# Local fallback used when Turso credentials are not set
DB_PATH=./hkbp_jatinegara.db

# JWT
JWT_SECRET=<generate-a-random-secret>
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# CORS
CORS_ORIGIN=http://localhost:5173

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
